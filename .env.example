# API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
SERPAPI_API_KEY=xxx

# Claude Max Proxy (alternative gratuite à l'API payante)
# Mettre "true" pour utiliser le proxy au lieu de l'API directe
USE_CLAUDE_PROXY=false
CLAUDE_PROXY_URL=http://127.0.0.1:4523

# Base de données
DATABASE_URL=sqlite:///./job_apply.db

# Configuration
LOG_LEVEL=INFO
